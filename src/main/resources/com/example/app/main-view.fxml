<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.app.MainController"
      spacing="12"
      styleClass="root">

    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <Label text="zpsbAPI - klient JavaFX" styleClass="title"/>

    <HBox spacing="16">
        <Label fx:id="apiInfoLabel" text="API:" styleClass="api-info"/>
    </HBox>

    <TabPane fx:id="entityTabs" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS"/>

    <Label fx:id="statusLabel"
           text="Gotowe do pracy."
           styleClass="result"/>
</VBox>
